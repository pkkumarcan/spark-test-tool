### 8.4 Per-field regeneration

```javascript
async function regenField(fieldId) {
  const instruction = prompt(`Instruction for regenerating "${fieldId}":\n(e.g. "Make this punchier", "More technical tone")`);
  if (!instruction) return;

  appendLog(`Regenerating field: ${fieldId} — "${instruction}"`, 'info');

  const el = document.querySelector(`[data-regen-id="${fieldId}"]`);
  const currentValue = el ? el.textContent.trim() : '';

  try {
    const res = await fetch('/api/regen/field', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        job_id: window.SPARK_STATE.job_id,
        field_id: fieldId,
        current_value: currentValue,
        instruction: instruction
      })
    });
    const data = await res.json();
    if (el && data.new_value) {
      el.textContent = data.new_value;
      window.SPARK_STATE.phase1_edited[fieldId] = data.new_value;
      appendLog(`Field "${fieldId}" regenerated successfully.`, 'info');
    }
  } catch (err) {
    appendLog(`Regen failed for "${fieldId}": ${err.message}`, 'error');
  }
}
```

