**JS: Update stepper dynamically**

```javascript
function updateStepper(steps) {
  // steps = { A: 'passed', B: 'passed', C: 'active', D: 'pending', ... }
  Object.entries(steps).forEach(([letter, state]) => {
    const pill = document.querySelector(`.step-pill[data-step="${letter}"]`);
    if (!pill) return;
    pill.className = `step-pill ${state}`;
    const icon = pill.querySelector('.step-icon');
    const pulse = pill.querySelector('.step-pulse');
    if (state === 'passed') {
      if (!icon) pill.innerHTML += `<i class="ti ti-check step-icon"></i>`;
      if (pulse) pulse.remove();
    } else if (state === 'active') {
      if (icon) icon.remove();
      if (!pulse) pill.innerHTML += `<div class="step-pulse"></div>`;
    } else {
      if (icon) icon.remove();
      if (pulse) pulse.remove();
    }
  });
}
```

