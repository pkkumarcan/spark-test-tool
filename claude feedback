  panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
}

function downloadExport() {
  const format = window.SPARK_STATE.export_format;
  const state = window.SPARK_STATE;
  const jobId = state.job_id || 'unknown';
  const channelId = state.phase1_response?.job_meta?.channel_name?.replace(/\s/g,'') || 'Channel';
  const date = new Date().toISOString().slice(0,10).replace(/-/g,'');
  const filename = `phase1_${channelId}_${jobId}_${date}.${format === 'json' ? 'json' : format === 'txt' ? 'txt' : 'md'}`;

  const wasEdited = Object.keys(state.phase1_edited).length > 0;
  let content = buildExportContent(format, wasEdited);

  const blob = new Blob([content], { type: 'text/plain' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = filename;
  a.click();
  appendLog(`Exported Phase 1 as ${filename}`, 'info');
}

function copyExportToClipboard() {
  const format = window.SPARK_STATE.export_format;
  const wasEdited = Object.keys(window.SPARK_STATE.phase1_edited).length > 0;
  const content = buildExportContent(format, wasEdited);
  navigator.clipboard.writeText(content).then(() => {
    appendLog('Phase 1 copied to clipboard.', 'info');
  });
}

function buildExportContent(format, wasEdited) {
  const p = window.SPARK_STATE.phase1_response;
  const e = window.SPARK_STATE.phase1_edited;
  const getVal = (path, fallback='') => e[path] ?? fallback;

  const reviewPrompt = `
# External LLM Review Brief
# Phase 1 Pre-Production Package — ${p?.job_meta?.channel_name}
# Job ID: ${p?.job_meta?.job_id} | Exported: ${new Date().toISOString()}
${wasEdited ? '# NOTE: This export reflects manually edited values.\n' : ''}
## Review instructions
You are a senior YouTube content strategist. Review the Phase 1 brief below.
For each section provide: score 1-10, 2-3 strengths, 2-3 weaknesses, one improvement.
Sections: market research quality, topic selection, title CTR, thumbnail effectiveness,
hook strength, script pacing, monetisation strategy, asset generation prompts.
Be direct. Quote specific weak lines. Do not be diplomatic.
---
`;
  if (format === 'json') {
    const merged = { ...p, _review_instructions: reviewPrompt, _edited_fields: e };
    return JSON.stringify(merged, null, 2);
  }
  // Build markdown — full content from phase1_response merged with edits
  return reviewPrompt + buildMarkdownExport(p, e);
}
