### 8.2 Edit mode toggle

```javascript
function toggleEditMode() {
  const state = window.SPARK_STATE;
  state.edit_mode_active = !state.edit_mode_active;

  const editBtn = document.getElementById('edit-assets-btn');
  const approveBtn = document.getElementById('approve-btn');
  const badge = document.getElementById('edit-mode-badge');

  // Toggle all data-field-path elements between display and editable
  document.querySelectorAll('[data-field-path]').forEach(el => {
    if (state.edit_mode_active) {
      el.setAttribute('contenteditable', 'true');
      el.classList.add('editable-active');
      el.addEventListener('input', trackEdit);
    } else {
      el.setAttribute('contenteditable', 'false');
      el.classList.remove('editable-active');
    }
  });

  if (state.edit_mode_active) {
    editBtn.textContent = '✕  Cancel Edits';
    editBtn.classList.add('active');
    approveBtn.textContent = 'Save Edits & Dispatch →';
    approveBtn.classList.add('edit-mode');
    badge.style.display = 'flex';
    appendLog('Edit mode activated. Fields are now editable.', 'warn');
  } else {
    editBtn.innerHTML = '<i class="ti ti-pencil"></i> Edit Assets';
    editBtn.classList.remove('active');
    approveBtn.innerHTML = '<i class="ti ti-send"></i> Approve & Dispatch to GPUs →';
    approveBtn.classList.remove('edit-mode');
    badge.style.display = 'none';
    window.SPARK_STATE.phase1_edited = {};
    appendLog('Edit mode cancelled. Changes discarded.', 'warn');
  }
}

function trackEdit(e) {
  const path = e.target.dataset.fieldPath;
  if (path) window.SPARK_STATE.phase1_edited[path] = e.target.textContent.trim();
}
```

