# ============================================================
# Spark Test Tool — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it is in .gitignore.
#
#   cp .env.example .env
# ============================================================

# --- Gateway ---
PORT=5050
HOST=0.0.0.0

# --- External Host Backends (running on your host machine) ---
OLLAMA_URL=http://host.docker.internal:11434
COMFYUI_URL=http://host.docker.internal:8188

# --- Isolated Container Backends ---
WHISPER_URL=http://whisper-stt:9000
F5_TTS_URL=http://f5-tts:8000

# --- Qdrant Vector DB ---
QDRANT_URL=http://qdrant:6333

# --- Default Models (adjust to what you have pulled in Ollama) ---
DEFAULT_LLM_MODEL=qwen3:8b
DEFAULT_VISION_MODEL=llama3.2-vision:11b
DEFAULT_EMBED_MODEL=nomic-embed-text:latest
DEFAULT_IMAGE_MODEL=flux1-schnell-q8.gguf
DEFAULT_VIDEO_MODEL=wan2.2_14b_q4.gguf

# --- Output ---
OUTPUT_DIR=/app/output
COMFYUI_OUTPUT_DIR=/comfyui-output

# --- Workspace (path to project root — used by coding agent) ---
WORKSPACE_ROOT=/home/youruser/AGGY/spark-test-tool

# --- Security ---
# Optional: Set an API key to protect sensitive endpoints
# SPARK_API_KEY=your_secret_key_here

# CORS: Comma-separated list of allowed origins (default: localhost only)
ALLOWED_ORIGINS=http://localhost:5050,http://127.0.0.1:5050

# --- Telemetry (Langfuse — optional) ---
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=http://host.docker.internal:3002

# --- RAG Engine (default: local Qdrant) ---
# Options: "local", "ragflow", "anythingllm"
RAG_ENGINE=local

# RAGFlow (only needed if RAG_ENGINE=ragflow)
# RAGFLOW_URL=http://host.docker.internal:9380
# RAGFLOW_API_KEY=
# RAGFLOW_DATASET_ID=

# AnythingLLM (only needed if RAG_ENGINE=anythingllm)
# ANYTHINGLLM_URL=http://host.docker.internal:3001
# ANYTHINGLLM_API_KEY=
# ANYTHINGLLM_WORKSPACE=spark-test-tool

# --- Search API Keys (for Research Agent — DuckDuckGo used if none set) ---
# TAVILY_API_KEY=
# SEARXNG_URL=
# GOOGLE_API_KEY=
# GOOGLE_CSE_ID=

# --- Optional LLM Providers ---
# DEEPSEEK_API_KEY=
# VLLM_URL=http://host.docker.internal:8000

# --- Yahoo Mail Organizer ---
# Generate an App Password at: https://login.yahoo.com/account/security
# NEVER use your main Yahoo password here.
YAHOO_EMAIL=your@yahoo.com
YAHOO_APP_PASSWORD=your_app_password_here
YAHOO_IMAP_SERVER=export.imap.mail.yahoo.com

# --- Dify Workflow Orchestrator ---
# DIFY_API_URL=http://host.docker.internal:3000
# DIFY_API_KEY=
